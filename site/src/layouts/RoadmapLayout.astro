---
import Base from "./base.astro";
import BrandIcon from "../components/BrandIcon.astro";
import { Cpu, Mail } from "@lucide/astro/icons";

interface Props {
	title: string;
	description?: string;
	theme: "devops" | "development";
	headerName: string;
	headerRole: string;
	resumeLabel?: string;
	resumeHref?: string;
	footerTag?: string;
}

const {
	title,
	description,
	theme,
	headerName,
	headerRole,
	resumeLabel = "View resume",
	resumeHref = "#",
	footerTag = "",
} = Astro.props;
---

<Base
	title={title}
	description={description}
	dataRoadmap={theme}
	bodyClass="bg-background-dark font-roadmap-sans text-slate-400 min-h-screen relative overflow-x-hidden"
>
	<div class="relative flex flex-col min-h-screen" id="roadmap-page-root">
		<header
			class="sticky top-0 z-50 border-b border-border-muted bg-black px-4 py-4 sm:px-8 sm:py-6"
		>
			<div
				class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-x-4 gap-y-3"
			>
				<div class="flex min-w-0 items-center gap-3 sm:gap-4">
					<div
						class="flex size-8 shrink-0 items-center justify-center border border-roadmap-primary/20 text-roadmap-primary"
					>
						<Cpu class="h-5 w-5" aria-hidden="true" />
					</div>
					<div class="min-w-0">
						<h2
							class="truncate text-[10px] font-bold uppercase tracking-[0.15em] text-white sm:text-xs sm:tracking-[0.2em]"
						>
							{headerName}
						</h2>
						<p
							class="truncate text-[9px] font-medium uppercase tracking-wider text-roadmap-primary sm:text-[10px]"
						>
							{headerRole}
						</p>
					</div>
				</div>
				<div class="ml-auto flex shrink-0 items-center gap-2 sm:gap-4">
					<a
						class="border border-white px-3 py-2 text-[9px] font-bold uppercase tracking-widest text-white no-underline transition-all hover:bg-white hover:text-black sm:px-5 sm:text-[10px]"
						href={resumeHref}
						target={resumeHref.startsWith("http") ? "_blank" : undefined}
						rel={resumeHref.startsWith("http")
							? "noopener noreferrer"
							: undefined}
					>
						{resumeLabel}
					</a>
					<a
						href="/"
						class="text-[9px] uppercase tracking-widest text-slate-500 no-underline transition-colors hover:text-roadmap-primary sm:text-[10px]"
					>
						Home
					</a>
				</div>
			</div>
		</header>
		<slot />
		<footer
			class="mt-auto border-t border-border-muted bg-black px-4 py-10 text-center sm:px-8 sm:py-12"
		>
			<p class="text-slate-600 text-[10px] uppercase tracking-[0.3em]">
				{footerTag}
			</p>
			<div class="flex justify-center gap-8 mt-8">
				<a
					class="text-slate-600 hover:text-roadmap-primary transition-colors"
					href="mailto:kylehartson@proton.me"
					aria-label="Email"
				>
					<Mail class="w-5 h-5" />
				</a>
				<a
					class="text-slate-600 hover:text-roadmap-primary transition-colors"
					href="https://github.com/khartson"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="GitHub"
				>
					<BrandIcon name="github" class="w-5 h-5" />
				</a>
			</div>
		</footer>
	</div>
	<script src="../scripts/roadmap-timeline-mount.ts"></script>
</Base>
