---
import SkillNode from "./SkillNode.astro";

type Node = {
	id: string;
	label: string;
	subtitle: string;
	icon: string;
	context?: string;
	overview: string;
	overviewBullets?: string[];
	professional: string;
	project: string;
};

interface Props {
	nodes: Node[];
	defaultActiveId: string;
	/** Minimum width of the timeline strip (wider when there are more nodes). */
	minTimelineWidth?: string;
}

const { nodes, defaultActiveId, minTimelineWidth = "min-w-[760px]" } =
	Astro.props;
---

<div
	class="w-full max-w-6xl overflow-x-auto pb-12 hide-scrollbar -mx-4 px-4 sm:mx-0 sm:px-0"
>
	<div
		class:list={[
			"relative flex items-center justify-between px-8 sm:px-12",
			minTimelineWidth,
		]}
		role="tablist"
		aria-label="Skill progression"
	>
		<div class="absolute top-[40px] right-8 left-8 h-px line-muted sm:right-12 sm:left-12"></div>
		{nodes.map((node) => (
			<SkillNode node={node} active={node.id === defaultActiveId} />
		))}
	</div>
</div>
