---
import RoadmapOverviewMount from "./RoadmapOverviewMount.astro";
import {
	resolveSkillDetails,
	type RoadmapSkill,
	type SkillLink,
} from "../../scripts/roadmap-skill-resolve";

type Node = {
	id: string;
	label: string;
	subtitle: string;
	icon: string;
	context?: string;
	professional?: string;
	project?: string;
	link?: SkillLink;
	skills: RoadmapSkill[];
};

interface Props {
	nodes: Node[];
	defaultActiveId: string;
	projectLinkLabel?: string;
	projectLinkHref?: string;
}

const {
	nodes,
	defaultActiveId,
	projectLinkLabel = "Explore repository",
	projectLinkHref = "#",
} = Astro.props;

const initial = nodes.find((n) => n.id === defaultActiveId) ?? nodes[0]!;
const initialSkill = initial.skills[0]!;
const resolved = resolveSkillDetails(initialSkill, {
	professional: initial.professional,
	project: initial.project,
	link:
		initial.link ??
		(projectLinkHref && projectLinkHref !== "#"
			? { label: projectLinkLabel, href: projectLinkHref }
			: undefined),
});
---

<div
	class="mt-8 w-full max-w-3xl px-2 opacity-100 transition-all duration-500 sm:mt-12 sm:px-0"
	id="roadmap-content-area"
	aria-live="polite"
	data-node-professional={initial.professional ?? ""}
	data-node-project={initial.project ?? ""}
	data-node-link-label={initial.link?.label ?? projectLinkLabel}
	data-node-link-href={initial.link?.href ?? projectLinkHref}
>
	<div
		class="grid grid-cols-1 gap-8 border-t border-border-muted pt-8 md:grid-cols-3 md:gap-12 md:pt-12"
	>
		<div class="space-y-4">
			<h4
				class="text-[10px] font-bold text-roadmap-primary uppercase tracking-[0.2em]"
			>
				General overview
			</h4>
			<RoadmapOverviewMount skills={initial.skills} activeIndex={0} />
			<p
				id="roadmap-content-context"
				class:list={[
					"text-[10px] text-slate-600 leading-relaxed uppercase tracking-[0.2em] mt-3",
					!initial.context?.trim() && "hidden",
				]}
			>
				{initial.context ?? ""}
			</p>
		</div>
		<div class="space-y-4">
			<h4
				class="text-[10px] font-bold text-roadmap-primary uppercase tracking-[0.2em]"
			>
				Professional use
			</h4>
			<p
				class="text-xs text-slate-500 leading-relaxed uppercase tracking-wider"
				id="roadmap-content-professional"
			>
				{resolved.professional}
			</p>
		</div>
		<div class="space-y-4">
			<h4
				class="text-[10px] font-bold text-roadmap-primary uppercase tracking-[0.2em]"
			>
				Project / link
			</h4>
			<div>
				<p
					class:list={[
						"text-xs text-slate-500 leading-relaxed uppercase tracking-wider mb-2",
						!resolved.showProject && "hidden",
					]}
					id="roadmap-content-project"
				>
					{resolved.project}
				</p>
				<a
					id="roadmap-content-project-link"
					class:list={[
						"text-[9px] text-roadmap-primary border-b border-roadmap-primary/30 pb-0.5 uppercase tracking-widest hover:border-roadmap-primary transition-all",
						!resolved.showLink && "hidden",
					]}
					href={resolved.showLink ? resolved.linkHref : undefined}
					target={
						resolved.showLink && resolved.linkHref.startsWith("http")
							? "_blank"
							: undefined
					}
					rel={
						resolved.showLink && resolved.linkHref.startsWith("http")
							? "noopener noreferrer"
							: undefined
					}
					aria-hidden={!resolved.showLink ? "true" : undefined}
					tabindex={!resolved.showLink ? -1 : undefined}
				>
					{resolved.linkLabel}
				</a>
			</div>
		</div>
	</div>
</div>
