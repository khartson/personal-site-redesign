---
interface Props {
	overview: string;
	overviewBullets?: string[];
}

const { overview, overviewBullets } = Astro.props;
const useList = overviewBullets != null && overviewBullets.length > 0;
const listClass = "list-none space-y-2.5 m-0 p-0";
const itemClass =
	"flex gap-2.5 text-left border-l-2 border-roadmap-primary/35 pl-3 py-0.5 text-slate-300 first:pt-0";
const paragraphClass =
	"text-white uppercase tracking-wider m-0 text-xs leading-relaxed";
---

<div
	id="roadmap-content-overview-mount"
	class="text-xs leading-relaxed normal-case tracking-normal"
>
	{
		useList ? (
			<ul class={listClass}>
				{overviewBullets!.map((line) => (
					<li class={itemClass}>
						<span>{line}</span>
					</li>
				))}
			</ul>
		) : (
			<p class={paragraphClass}>
				{overview}
			</p>
		)
	}
</div>
