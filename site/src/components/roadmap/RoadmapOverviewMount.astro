---
import type { RoadmapSkill } from "../../scripts/roadmap-skill-resolve";

interface Props {
	skills: RoadmapSkill[];
	/** Index of the initially active skill (usually 0). */
	activeIndex?: number;
}

const { skills, activeIndex = 0 } = Astro.props;
const listClass = "list-none space-y-2.5 m-0 p-0";
const itemBaseClass =
	"roadmap-skill-item flex gap-2.5 text-left border-l-2 pl-3 py-0.5 first:pt-0 cursor-pointer transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-roadmap-primary focus-visible:outline-offset-2";
const itemIdleClass = "border-roadmap-primary/35 text-slate-300 hover:border-roadmap-primary/70 hover:text-slate-100";
const itemActiveClass = "border-roadmap-primary text-white";
---

<ul
	id="roadmap-content-overview-mount"
	class:list={[listClass, "text-xs leading-relaxed normal-case tracking-normal"]}
	role="listbox"
	aria-label="Skills in this pillar"
>
	{
		skills.map((skill, index) => {
			const active = index === activeIndex;
			return (
				<li
					class:list={[
						itemBaseClass,
						active ? itemActiveClass : itemIdleClass,
					]}
					role="option"
					tabindex={active ? 0 : -1}
					aria-selected={active ? "true" : "false"}
					data-skill-index={String(index)}
					data-label={skill.label}
					data-professional={skill.professional ?? ""}
					data-project={skill.project ?? ""}
					data-link-label={skill.link?.label ?? ""}
					data-link-href={skill.link?.href ?? ""}
				>
					<span>{skill.label}</span>
				</li>
			);
		})
	}
</ul>
