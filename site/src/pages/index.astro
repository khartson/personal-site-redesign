---
import Base from "../layouts/base.astro"
import { Rocket } from "@lucide/astro";
import { UserRound } from '@lucide/astro/icons'
---

<Base title="Kyle Hartson - Welcome">
<body class="bg-green font-display text-white antialiased overflow-x-hidden">
<div class="relative min-h-screen flex flex-col items-center justify-center">
<main class="relative z-10 flex flex-col items-center justify-center px-6 py-20 text-center max-w-4xl mx-auto">
<div class="text-zinc-500 text-[10px] font-bold uppercase tracking-[0.3em] mb-12">
            Mapping my development journey
        </div>
<h1 class="animate-typewriter overflow-hidden whitespace-nowrap text-5xl md:text-7xl font-bold tracking-tight leading-tight mb-8">
			Hi, I'm Kyle Hartson
        </h1>
<p class="text-zinc-500 text-sm md:text-base max-w-md mx-auto leading-relaxed mb-16">
            This is a minimalist map of my professional journey and technical expertise.
        </p>
<div class="flex flex-col sm:flex-row gap-8 justify-center w-full max-w-md">
<button class="flex items-center justify-center gap-3 flex-1 bg-primary text-white h-14 px-8 rounded-full font-semibold transition-all shadow-[0_0_20px_rgba(0,112,243,0.3)] hover:shadow-[0_0_30px_rgba(0,112,243,0.5)]">
<span>Explore My Skills</span>
<Rocket class="w-6 h-6"/>
</button>
<button class="flex items-center justify-center gap-3 flex-1 text-zinc-400 hover:text-white h-14 px-8 rounded-full font-semibold transition-all">
<span>Intro &amp; Socials</span>
<UserRound class="w-6 h-6"/>
</button>
</div>
</main>
<!-- Social Links Footer -->
<footer class="absolute bottom-12 flex gap-12 text-zinc-600 text-xs font-medium tracking-widest uppercase z-10">
<a class="hover:text-white transition-colors" href="#">GitHub</a>
<a class="hover:text-white transition-colors" href="#">LinkedIn</a>
<a class="hover:text-white transition-colors" href="#">Resume</a>
</footer>
</div>
</Base>

