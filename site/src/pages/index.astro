---
import Base from "../layouts/base.astro";
import { CloudCog, CodeXml, Layers } from "@lucide/astro/icons";
---

<Base
	title="Kyle Hartson — Welcome"
	description="Kyle Hartson — full-stack and systems engineer. Explore interactive roadmaps for DevOps & infrastructure and software development, with resumes and links to GitHub and LinkedIn."
>
	<div
		class="relative flex min-h-screen w-full max-w-full flex-col items-center justify-center px-4 sm:px-6"
	>
		<header
			class="absolute inset-x-0 top-0 z-10 flex items-center justify-center px-4 py-8 sm:px-6 sm:py-12"
		>
			<div class="flex items-center justify-center gap-2">
				<Layers class="text-primary w-6 h-6 sm:w-7 sm:h-7" aria-hidden="true" />
				<h2 class="text-xs sm:text-sm font-medium tracking-[0.15em] sm:tracking-[0.2em] uppercase">
					Kyle Hartson
				</h2>
			</div>
		</header>
		<main
			class="relative z-10 flex w-full max-w-4xl flex-col items-center justify-center px-2 py-24 pb-32 text-center sm:px-6 sm:py-20 sm:pb-28"
		>
			<div
				class="mb-10 max-w-xs text-zinc-500 text-[10px] font-bold uppercase tracking-[0.2em] sm:mb-12 sm:max-w-none sm:tracking-[0.3em]"
			>
				Mapping my development journey
			</div>
			<h1
				class="animate-typewriter mb-6 max-w-full overflow-hidden text-3xl font-bold leading-tight tracking-tight whitespace-normal sm:mb-8 sm:whitespace-nowrap sm:text-5xl md:text-7xl"
			>
				Hi, I'm Kyle Hartson
			</h1>
			<p
				class="mx-auto mb-12 max-w-md text-zinc-500 text-sm leading-relaxed sm:mb-16 md:text-base"
			>
				This is a minimalist map of my professional journey and technical
				expertise.
			</p>
			<div
				class="flex w-full max-w-md flex-col justify-center gap-4 sm:flex-row sm:gap-8"
			>
				<a
					href="/roadmap/devops/"
					class="flex h-14 w-full items-center justify-center gap-3 rounded-full bg-primary px-6 font-semibold text-white no-underline shadow-[0_0_20px_rgba(0,112,243,0.3)] transition-all hover:shadow-[0_0_30px_rgba(0,112,243,0.5)] sm:flex-1 sm:px-8"
				>
					<span class="text-sm sm:text-base">DevOps &amp; infrastructure</span>
					<CloudCog class="h-6 w-6 shrink-0" aria-hidden="true" />
				</a>
				<a
					href="/roadmap/development/"
					class="flex h-14 w-full items-center justify-center gap-3 rounded-full border border-transparent px-6 font-semibold text-zinc-400 no-underline transition-all hover:border-white/10 hover:text-white sm:flex-1 sm:px-8"
				>
					<span class="text-sm sm:text-base">Software development</span>
					<CodeXml class="h-6 w-6 shrink-0" aria-hidden="true" />
				</a>
			</div>
		</main>
		<footer
			id="socials"
			class="absolute inset-x-0 bottom-6 z-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 px-4 text-center text-zinc-600 text-[10px] font-medium uppercase tracking-widest sm:bottom-12 sm:gap-x-12 sm:text-xs"
		>
			<a
				class="hover:text-white transition-colors"
				href="https://github.com/khartson"
				target="_blank"
				rel="noopener noreferrer">GitHub</a
			>
			<a
				class="hover:text-white transition-colors"
				href="https://www.linkedin.com/in/kyle-hartson/"
				target="_blank"
				rel="noopener noreferrer">LinkedIn</a
			>
			<a
				class="hover:text-white transition-colors"
				href="/Resume_April_2026___DevOps.pdf"
				target="_blank"
				rel="noopener noreferrer">Resume</a
			>
		</footer>
	</div>
</Base>
