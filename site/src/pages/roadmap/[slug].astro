---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import RoadmapLayout from "../../layouts/RoadmapLayout.astro";
import SkillTimeline from "../../components/roadmap/SkillTimeline.astro";
import RoadmapDetailPanels from "../../components/roadmap/RoadmapDetailPanels.astro";

export const getStaticPaths = (async () => {
	const roadmaps = await getCollection("roadmaps");
	return roadmaps.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { data } = entry;
const defaultActiveId = data.nodes[0]!.id;
const pageTitle = data.pageTitle ?? `${data.title} | Kyle Hartson`;
const timelineMinWidth =
	data.nodes.length >= 5 ? "min-w-[1180px]" : "min-w-[760px]";
const metaDescription = [data.headline, data.subheadline]
	.filter((s): s is string => Boolean(s?.trim()))
	.join(". ");
---

<RoadmapLayout
	title={pageTitle}
	description={metaDescription}
	theme={data.theme}
	headerName={data.headerName ?? "Kyle Hartson"}
	headerRole={data.headerRole ?? ""}
	resumeLabel={data.resumeLabel}
	resumeHref={data.resumeHref}
	footerTag={data.footerTag ?? ""}
>
	<main class="flex w-full flex-1 flex-col items-center px-4 py-12 sm:px-6 sm:py-20">
		<div class="mb-16 w-full max-w-2xl px-2 text-center sm:mb-24">
			<h1
				class="mb-6 text-2xl font-light tracking-tight text-white sm:text-3xl md:text-4xl"
			>
				{data.headline}
			</h1>
			<div class="mx-auto mb-6 h-px w-12 bg-roadmap-primary"></div>
			{
				data.subheadline && (
					<p class="mx-auto max-w-xl text-slate-500 text-xs uppercase leading-loose tracking-[0.12em] sm:text-sm sm:tracking-widest">
						{data.subheadline}
					</p>
				)
			}
		</div>
		<SkillTimeline
			nodes={data.nodes}
			defaultActiveId={defaultActiveId}
			minTimelineWidth={timelineMinWidth}
		/>
		<RoadmapDetailPanels
			nodes={data.nodes}
			defaultActiveId={defaultActiveId}
		/>
	</main>
</RoadmapLayout>
